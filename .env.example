# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Optional fallback if your project still uses the anon key name
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Set this to your local dev port or deployed domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Real AI visibility checks (server-side only — never expose to the client)
# Get a FREE key at https://console.groq.com/keys → used by /api/visibility-check,
# /api/verify-brand, and /api/mention-opportunities.
GROQ_API_KEY=your_groq_api_key
# Optional: override the Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Real multi-engine AI visibility (server-side only). Each key makes that engine
# genuinely LIVE in the Prompt Rank Tracker; engines without a key fall back to
# Groq (clearly labelled "fallback" in the UI). Add the ones you have.
# OPENAI_API_KEY=sk-...          # ChatGPT     (https://platform.openai.com/api-keys)
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=...             # Gemini      (https://aistudio.google.com/apikey)
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_API_KEY=sk-ant-...   # Claude      (https://console.anthropic.com/settings/keys)
# ANTHROPIC_MODEL=claude-haiku-4-5
# PERPLEXITY_API_KEY=pplx-...    # Perplexity  (https://www.perplexity.ai/settings/api)
# PERPLEXITY_MODEL=sonar

# Optional tuning for visibility caching + rate limiting (sensible defaults shown)
# VISIBILITY_CACHE_TTL_SECONDS=21600   # reuse identical prompt+brand results for 6h
# VISIBILITY_RATE_LIMIT_MAX=15         # max checks per client per window
# VISIBILITY_RATE_LIMIT_WINDOW=300     # rate-limit window in seconds (5 min)

# Supabase service role key (server-side only) — lets the Stripe webhook update
# subscription_tier. Find it in Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Turn paid plans on. Leave unset/false to launch free-only — paid plans show
# "Coming soon" and no checkout is attempted. Set to "true" once the Stripe
# keys/prices/webhook below are all configured to go live with payments.
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# Dodo Payments — collect subscription payments
# Get your API key at https://app.dodopayments.com → Settings → API Keys
DODO_PAYMENTS_API_KEY=your_dodo_api_key
DODO_WEBHOOK_SECRET=your_dodo_webhook_secret
# Set to "live_mode" when ready for real payments (default: test_mode)
DODO_PAYMENTS_ENV=test_mode
# Product IDs from Dodo Payments dashboard → Products (one per plan per cycle)
DODO_PRODUCT_PRO=pdt_xxx
DODO_PRODUCT_GROWTH=pdt_xxx
DODO_PRODUCT_AGENCY=pdt_xxx
# Optional yearly Product IDs (20% off). If unset, yearly falls back to monthly.
DODO_PRODUCT_PRO_YEARLY=pdt_xxx
DODO_PRODUCT_GROWTH_YEARLY=pdt_xxx
DODO_PRODUCT_AGENCY_YEARLY=pdt_xxx

# Error tracking (Sentry). Leave unset to disable — error tracking is a no-op
# until you create a free Sentry project and paste its DSN here. The DSN is
# public/safe to expose. Find it in Sentry → Project Settings → Client Keys.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oXXXX.ingest.sentry.io/XXXX
# Optional — only needed to upload source maps at build time (better stack
# traces). Set these in your host (Vercel), not in client code.
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_xxx
